# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Database (ローカル実行: SQLite / Docker: PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./lt_oosaka.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/lt_oosaka

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Ollama (ローカル実行: localhost / Docker: llm)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_URL=http://llm:11434

# App (本番では強力なランダム文字列に変更すること)
SECRET_KEY=changeme
GITHUB_CONNECTION_TOKEN_ENCRYPTION_KEY=
APP_ENV=development
PR_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30
LEARNING_RETENTION_DAYS=365
DIGEST_RETENTION_DAYS=365
LOKI_PUSH_URL=
LOKI_USERNAME=
LOKI_PASSWORD=
LOKI_TENANT_ID=
LOKI_RETENTION_JOB=lt_oosaka-retention
LOKI_TIMEOUT_SECONDS=5.0

# CORS (カンマ区切りで複数指定可)
# CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# GitHub App (Webhook連携時に設定)
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=

# GitHub OAuth (ログイン連携時に設定)
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback
